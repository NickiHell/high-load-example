# =============================================================================
# positions-service — переменные окружения
#
# Docker Compose читает файл `.env` из корня проекта (рядом с compose-файлом).
# Скопируйте и при необходимости измените:
#   cp .env.example .env
#
# Без `.env` используются значения по умолчанию, заданные в docker-compose.yml.
# =============================================================================

# --- PostgreSQL (сервис `postgres` + строка подключения приложения) ----------
POSTGRES_USER=positions
POSTGRES_PASSWORD=positions
POSTGRES_DB=positions

# Публикация Postgres на хост (хост:контейнер)
POSTGRES_PUBLISH_PORT=5432

# --- Приложение (сервис `app`) ------------------------------------------------
# Полный URL async SQLAlchemy. В Compose по умолчанию собирается из POSTGRES_*.
# Задайте вручную, если нужен нестандартный хост или параметры подключения.
# DATABASE_URL=postgresql+asyncpg://positions:positions@postgres:5432/positions
# Пул asyncpg (при высокой конкуренции load/wave не оставляйте дефолт 5+10).
# DATABASE_POOL_SIZE=30
# DATABASE_MAX_OVERFLOW=60

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_POSITIONS=positions
KAFKA_CLIENT_ID=positions-service

# Число воркеров Uvicorn в контейнере приложения
UVICORN_WORKERS=1

# Публикация API на хост
APP_PUBLISH_PORT=8000

# Встроенный генератор (POST /api/v1/load/wave), вызовы через ASGI in-process
LOAD_GENERATOR_ENABLED=true

# --- Prometheus / Grafana -----------------------------------------------------
PROMETHEUS_PUBLISH_PORT=9090

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PUBLISH_PORT=3000

# --- Elasticsearch / Kibana -------------------------------------------------
ELASTICSEARCH_PUBLISH_PORT=9200
KIBANA_PUBLISH_PORT=5601

# Память JVM для Elasticsearch (образ ожидает формат -Xms/-Xmx)
ES_JAVA_OPTS=-Xms512m -Xmx512m

# --- Kafka (брокер; служебные переменные образа) ------------------------------
KAFKA_PUBLISH_PORT=9092
